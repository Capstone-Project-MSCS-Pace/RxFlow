# Host-facing ports
CLIENT_HOST_PORT=3000
SERVER_HOST_PORT=5000
POSTGRES_HOST_PORT=5432

# Container internal ports
CLIENT_CONTAINER_PORT=3000
SERVER_CONTAINER_PORT=5000
POSTGRES_CONTAINER_PORT=5432

# Shared URL settings
# Leave REACT_APP_API_BASE_URL empty in dev to use relative /api with proxy.
REACT_APP_API_BASE_URL=
REACT_APP_API_BASE_PATH=/api
DEV_SERVER_PROXY_TARGET=http://server:5000

# Public URLs used by server-generated links and CORS
CLIENT_APP_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Internal service URLs
REDIS_URL=redis://redis:6379
